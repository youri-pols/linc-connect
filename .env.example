# Supabase
# Project URL + anon (public) key — from Supabase Dashboard → Project
# Settings → API. Safe to ship to the browser (prefixed NEXT_PUBLIC_).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — from the same Supabase API page. NEVER prefix with
# NEXT_PUBLIC_; this key bypasses RLS and must stay server-side. Used
# by the team page to list Auth users via the admin API.
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth
# Credentials from Google Cloud Console → APIs & Services → Credentials.
# Primary use is the Supabase Google provider config, but the server
# ALSO reads these directly to refresh the Google access token when a
# calendar call returns 401 (see lib/google/fetch.ts). Without them the
# "Plan afspraak" modal breaks ~1 hour after login.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
