# Supabase
# Project URL + anon (public) key — from Supabase Dashboard → Project
# Settings → API. Safe to ship to the browser (prefixed NEXT_PUBLIC_).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — from the same Supabase API page. NEVER prefix with
# NEXT_PUBLIC_; this key bypasses RLS and must stay server-side. Used
# by the team page to list Auth users via the admin API.
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth
# Credentials from Google Cloud Console → APIs & Services → Credentials.
# Configured inside Supabase → Authentication → Providers → Google, so
# the app itself doesn't read these at runtime, but keep them here as a
# reference for provisioning a fresh environment.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
